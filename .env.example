# ══════════════════════════════════════════════════════════════
# Grafted Services — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════

# ── Shared ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Main Receptionist (server.js, port 3000) ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=          # e.g. +441234567890 — the receptionist's number

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=          # e.g. https://your-railway-url.up.railway.app/auth/callback

SESSION_SECRET=                # any long random string
DASHBOARD_USERNAME=            # login username for /dashboard
DASHBOARD_PASSWORD=            # login password for /dashboard

BUSINESS_NAME=Grafted Services
BUSINESS_OWNER_NAME=Jake

BASE_LAT=53.4282               # Didsbury M20 latitude
BASE_LNG=-2.2141               # Didsbury M20 longitude
FREE_RADIUS_MILES=10           # free zone radius
CALLOUT_RATE_PER_MILE=1.50    # £ per mile beyond free zone
MAX_RADIUS_MILES=25            # decline beyond this

# ── Jake Outbound Cold Caller (jake/jake-server.js, port 3001) ──
JAKE_PHONE_NUMBER=             # Jake's dedicated Twilio number e.g. +441234567891
JAKE_PORT=3001
JAKE_RATE_LIMIT_MS=2000        # ms delay between campaign messages (don't go below 1000)
JAKE_DRY_RUN=false             # set to true to test campaign without sending

# Override these only if Jake uses a DIFFERENT Twilio account:
# JAKE_TWILIO_ACCOUNT_SID=
# JAKE_TWILIO_AUTH_TOKEN=

# ── Demo Receptionist (demo/demo-server.js, port 3002) ──────────
DEMO_PHONE_NUMBER=             # Demo Twilio number e.g. +441234567892
DEMO_PORT=3002

# Override these only if demo uses a DIFFERENT Twilio account:
# DEMO_TWILIO_ACCOUNT_SID=
# DEMO_TWILIO_AUTH_TOKEN=
