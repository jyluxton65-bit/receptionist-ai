# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+44xxxxxxxxxx

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# For local dev: http://localhost:3000/auth/callback
# For production: https://your-app.railway.app/auth/callback
GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/callback
GOOGLE_CALENDAR_ID=primary

# ── Business Info ─────────────────────────────────────────────────────────────
BUSINESS_NAME=Grafted Services
BUSINESS_OWNER_NAME=Jake
BUSINESS_SERVICES=tree surgery, crown reduction, tree removal, stump grinding, hedge trimming, emergency tree work
BUSINESS_AREA=Didsbury and South Manchester (within 25 miles)

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change_me_to_something_random_and_long

# ── Dashboard Login ───────────────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me

# ── Callout Fee Calculator ────────────────────────────────────────────────────
# Base location: Didsbury, Manchester M20
BASE_LAT=53.4282
BASE_LNG=-2.2141
FREE_RADIUS_MILES=10
CALLOUT_RATE_PER_MILE=1.50
MAX_RADIUS_MILES=25
